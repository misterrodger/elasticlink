{
  "name": "elasticlink",
  "version": "1.0.0-beta.2",
  "description": "Type-safe, lightweight Elasticsearch query builder with fluent API",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "audit": "better-npm-audit audit --level=high",
    "ship": "bash scripts/ship.sh",
    "prepublishOnly": "npm run build",
    "type-check": "tsc --noEmit",
    "depcheck": "depcheck --ignores='elasticlink' --ignore-patterns='examples/*'",
    "jscpd": "jscpd src/ --min-lines 10 --min-tokens 100 --ignore \"**/__tests__/**\"",
    "license-check": "license-checker --summary --onlyAllow 'MIT;MIT*;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;0BSD;CC0-1.0;CC-BY-3.0;Python-2.0;Unlicense;MPL-2.0;BlueOak-1.0.0;(MIT AND CC-BY-3.0);(WTFPL OR MIT)'"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/misterrodger/elasticlink.git"
  },
  "author": "John Rodger",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/misterrodger/elasticlink/issues"
  },
  "homepage": "https://github.com/misterrodger/elasticlink#readme",
  "keywords": [
    "elasticsearch",
    "query-builder",
    "typescript",
    "type-safe",
    "typesafe",
    "elastic",
    "search",
    "query-dsl",
    "fluent-api",
    "type-safety",
    "strongly-typed",
    "autocomplete",
    "elasticsearch-client",
    "chain",
    "chainable"
  ],
  "peerDependencies": {
    "@elastic/elasticsearch": ">=9.0.0"
  },
  "devDependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "better-npm-audit": "^3.11.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.2.1",
    "eslint-plugin-functional": "^9.0.4",
    "globals": "^17.5.0",
    "jscpd": "^4.0.9",
    "license-checker": "^25.0.1",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
