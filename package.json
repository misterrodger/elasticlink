{
  "name": "elasticlink",
  "version": "0.8.0-beta",
  "description": "Type-safe, lightweight Elasticsearch query builder with fluent API",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "audit": "better-npm-audit audit --level=high",
    "prepublishOnly": "npm run build",
    "type-check": "tsc --noEmit",
    "depcheck": "depcheck",
    "jscpd": "jscpd src/ --min-lines 10 --min-tokens 100 --ignore \"**/__tests__/**\"",
    "license-check": "license-checker --summary --onlyAllow 'MIT;MIT*;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;0BSD;CC0-1.0;CC-BY-3.0;Python-2.0;Unlicense;MPL-2.0;BlueOak-1.0.0;(MIT AND CC-BY-3.0);(WTFPL OR MIT)'"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/misterrodger/elasticlink.git"
  },
  "author": "John Rodger",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/misterrodger/elasticlink/issues"
  },
  "homepage": "https://github.com/misterrodger/elasticlink#readme",
  "keywords": [
    "elasticsearch",
    "query-builder",
    "typescript",
    "type-safe",
    "typesafe",
    "elastic",
    "search",
    "query-dsl",
    "fluent-api",
    "type-safety",
    "strongly-typed",
    "autocomplete",
    "elasticsearch-client",
    "chain",
    "chainable"
  ],
  "peerDependencies": {
    "@elastic/elasticsearch": ">=9.0.0"
  },
  "devDependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.12",
    "better-npm-audit": "^3.11.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.0.3",
    "eslint-plugin-functional": "^9.0.4",
    "globals": "^17.4.0",
    "jscpd": "^4.0.8",
    "license-checker": "^25.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
